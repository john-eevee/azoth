channel "ref" type="literal" source="s3://my-bucket/refs/hg38.fa"
channel "samples" type="path" source="s3://my-bucket/data/*.fastq.gz"
channel "bams" type="result" source="align"
channel "vcfs" type="result" source="call_variants"
channel "merged" type="result" source="merge_vcfs"

process "align" {
    image "genomics/bwa:0.7.17"
    command "bwa mem -t {cpu} {ref} {reads} | samtools sort -o {output}"
    inputs {
        ref "ref"
        reads "samples"
    }
    outputs {
        output "s3://my-bucket/aligned/{reads.stem}.bam"
    }
    resources cpu=8 mem=16.0 disk=50.0
}

process "call_variants" {
    image "genomics/gatk:4.4"
    command "gatk HaplotypeCaller -R {ref} -I {bam} -O {vcf}"
    inputs {
        bam "bams"
        ref "ref"
    }
    outputs {
        vcf "s3://my-bucket/variants/{bam.stem}.vcf.gz"
    }
    resources cpu=4 mem=32.0 disk=20.0
}

process "merge_vcfs" {
    image "genomics/bcftools:1.18"
    command "bcftools merge {vcfs} -o {merged}"
    inputs {
        vcfs "vcfs"
    }
    outputs {
        merged "s3://my-bucket/cohort/merged.vcf.gz"
    }
    resources cpu=2 mem=8.0 disk=10.0
}

workflow "genomics_pipeline" {
}
