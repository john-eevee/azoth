{
  "channels": [
    {
      "channel_type": "literal",
      "format": "generic",
      "id": "id_0",
      "source": {
        "kind": "literal",
        "value": "s3://my-bucket/refs/hg38.fa"
      }
    },
    {
      "channel_type": "path",
      "format": "generic",
      "id": "id_1",
      "source": {
        "glob": "s3://my-bucket/data/*.fastq.gz",
        "kind": "from_path"
      }
    },
    {
      "channel_type": "result",
      "format": "generic",
      "id": "chan_id_2",
      "source": {
        "kind": "result",
        "process_id": "id_2"
      }
    },
    {
      "channel_type": "result",
      "format": "generic",
      "id": "chan_id_3",
      "source": {
        "kind": "result",
        "process_id": "id_3"
      }
    },
    {
      "channel_type": "result",
      "format": "generic",
      "id": "chan_id_4",
      "source": {
        "kind": "result",
        "process_id": "id_4"
      }
    }
  ],
  "name": "genomics_pipeline",
  "processes": [
    {
      "command": "bwa mem -t {cpu} {ref} {reads} | samtools sort -o {output}",
      "id": "id_2",
      "image": {
        "tag": "genomics/bwa:0.7.17"
      },
      "inputs": {
        "reads": {
          "channel_id": "id_1",
          "format": "generic"
        },
        "ref": {
          "channel_id": "id_0",
          "format": "generic"
        }
      },
      "name": "align",
      "outputs": {
        "type": "static",
        "value": {
          "output": {
            "format": "generic",
            "uri": "s3://my-bucket/aligned/{reads.stem}.bam"
          }
        }
      },
      "resources": {
        "cpu": 8.0,
        "disk": 50.0,
        "mem": 16.0
      }
    },
    {
      "command": "gatk HaplotypeCaller -R {ref} -I {bam} -O {vcf}",
      "id": "id_3",
      "image": {
        "tag": "genomics/gatk:4.4"
      },
      "inputs": {
        "bam": {
          "channel_id": "chan_id_2",
          "format": "generic"
        },
        "ref": {
          "channel_id": "id_0",
          "format": "generic"
        }
      },
      "name": "call_variants",
      "outputs": {
        "type": "static",
        "value": {
          "vcf": {
            "format": "generic",
            "uri": "s3://my-bucket/variants/{bam.stem}.vcf.gz"
          }
        }
      },
      "resources": {
        "cpu": 4.0,
        "disk": 20.0,
        "mem": 32.0
      }
    },
    {
      "command": "bcftools merge {vcfs} -o {merged}",
      "id": "id_4",
      "image": {
        "tag": "genomics/bcftools:1.18"
      },
      "inputs": {
        "vcfs": {
          "channel_id": "chan_id_3",
          "format": "generic"
        }
      },
      "name": "merge_vcfs",
      "outputs": {
        "type": "static",
        "value": {
          "merged": {
            "format": "generic",
            "uri": "s3://my-bucket/cohort/merged.vcf.gz"
          }
        }
      },
      "resources": {
        "cpu": 2.0,
        "disk": 10.0,
        "mem": 8.0
      }
    }
  ],
  "version": 1
}
