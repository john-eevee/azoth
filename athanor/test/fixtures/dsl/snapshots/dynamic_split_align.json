{
  "channels": [
    {
      "channel_type": "literal",
      "format": "generic",
      "id": "ref",
      "source": {
        "kind": "literal",
        "value": "s3://my-bucket/refs/hg38.fa"
      }
    },
    {
      "channel_type": "literal",
      "format": "generic",
      "id": "reads",
      "source": {
        "kind": "literal",
        "value": "s3://my-bucket/data/sample_R1.fq.gz"
      }
    },
    {
      "channel_type": "result",
      "format": "generic",
      "id": "chunks",
      "source": {
        "kind": "result",
        "process_id": "split_genome"
      }
    },
    {
      "channel_type": "result",
      "format": "generic",
      "id": "bams",
      "source": {
        "kind": "result",
        "process_id": "align_chunk"
      }
    }
  ],
  "name": "dynamic_split_align",
  "processes": [
    {
      "command": "split_tool {ref} --output-dir ./chunks/",
      "id": "split_genome",
      "image": {
        "tag": "genomics/tools:latest"
      },
      "inputs": {
        "ref": {
          "channel_id": "ref",
          "format": "generic"
        }
      },
      "name": "split_genome",
      "outputs": {
        "type": "glob",
        "value": [
          "./chunks/*.fa"
        ]
      },
      "resources": {
        "cpu": 2.0,
        "disk": 20.0,
        "mem": 4.0
      }
    },
    {
      "command": "bwa mem -t {cpu} {chunk} {reads} -o {output}",
      "id": "align_chunk",
      "image": {
        "tag": "genomics/bwa:0.7.17"
      },
      "inputs": {
        "chunk": {
          "channel_id": "chunks",
          "format": "generic"
        },
        "reads": {
          "channel_id": "reads",
          "format": "generic"
        }
      },
      "name": "align_chunk",
      "outputs": {
        "type": "static",
        "value": {
          "output": {
            "format": "generic",
            "uri": "s3://my-bucket/aligned/{chunk.stem}.bam"
          }
        }
      },
      "resources": {
        "cpu": 8.0,
        "disk": 50.0,
        "mem": 16.0
      }
    }
  ],
  "version": 1
}
